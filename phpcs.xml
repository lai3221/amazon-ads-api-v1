<?xml version="1.0"?>
<ruleset name="Amazon Ads API v1 SDK">
    <description>PSR-12 coding standard for runtime and generated SDK code.</description>

    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg name="parallel" value="8"/>
    <arg name="warning-severity" value="0"/>

    <file>src</file>
    <file>tests</file>
    <file>tools/generate-sdk.php</file>
    <file>tools/verify-coverage.php</file>

    <exclude-pattern>vendor/*</exclude-pattern>

    <rule ref="PSR12"/>
</ruleset>
